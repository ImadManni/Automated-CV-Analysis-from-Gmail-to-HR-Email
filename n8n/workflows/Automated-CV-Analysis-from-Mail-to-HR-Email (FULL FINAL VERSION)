        "jsCode": "const data = $input.first().json;\nconst offers = Array.isArray(data.offers) ? data.offers : [];\nconst merge = $('2 - Merge (Email + API response)').first().json;\nconst subjectRaw = String(merge.subject || '').trim();\n\nfunction norm(s) {\n  return String(s || '')\n    .toLowerCase()\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/^re:\\s*|^fwd:\\s*/gi, '')\n    .replace(/[\\u2010-\\u2015\\u2212]/g, '-')\n    .replace(/[_\\u2013\\u2014\\-]+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction cleanSubject(v) {\n  return String(v || '').replace(/^re:\\s*|^fwd:\\s*/gi, '').trim();\n}\n\nconst subjectTitle = cleanSubject(subjectRaw);\nconst offerTitle = subjectTitle || null;\n\nlet offerDescription = '';\nlet bestScore = 0;\n\nif (offerTitle) {\n  const subjN = norm(offerTitle);\n  let best = null;\n  let bestLocal = -1;\n\n  for (const o of offers) {\n    const title = String(o.title || '').trim();\n    if (!title) continue;\n    const tN = norm(title);\n    let sc = 0;\n    if (tN === subjN) sc = 100;\n    else if (tN.includes(subjN) || subjN.includes(tN)) sc = 70;\n    else {\n      const subjTokens = subjN.split(' ').filter(Boolean);\n      const titleTokens = tN.split(' ').filter(Boolean);\n      const overlap = subjTokens.filter((t) => titleTokens.includes(t)).length;\n      sc = overlap * 8;\n    }\n    if (sc > bestLocal) {\n      bestLocal = sc;\n      best = o;\n    }\n  }\n\n  if (best) {\n    bestScore = bestLocal;\n    offerDescription = [best.company, best.location].filter(Boolean).join(' - ');\n  }\n}\n\nreturn [{ json: { offerTitle, offerDescription, subject: subjectRaw, _offerMatchScore: bestScore } }];"
